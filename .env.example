# Flask Configuration
FLASK_ENV=production
PORT=8000

# MLflow Configuration - Local
MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow Configuration - DagsHub Remote
# Uncomment dan isi jika ingin menggunakan DagsHub
# MLFLOW_TRACKING_URI=https://dagshub.com/<username>/<repo>.mlflow
# DAGSHUB_USERNAME=<your_dagshub_username>
# DAGSHUB_TOKEN=<your_dagshub_token>

# Model & Data Configuration
MLFLOW_EXPERIMENT_NAME=attrition-prediction
DATA_PATH=data/data_clean.csv
MODEL_PATH=models/model.pkl

# Database Configuration (optional, untuk aplikasi yang lebih kompleks)
# DATABASE_URL=postgresql://user:password@localhost/dbname
